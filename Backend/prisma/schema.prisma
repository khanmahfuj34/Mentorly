generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  role Role @default(STUDENT)

  isVerified Boolean @default(false)
  isBlocked  Boolean @default(false)

  tutorProfile     TutorProfile?
  studentProfile   StudentProfile?
  tuitionRequests  TuitionRequest[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  TutorApplication TutorApplication[]
  studentBookings  Booking[]          @relation("StudentBookings")
  tutorBookings    Booking[]          @relation("TutorBookings")
  reviewsAsStudent Review[]           @relation("StudentReviews")
  reviewsAsTutor   Review[]           @relation("TutorReviews")
}

model TutorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  bio          String?
  profilePhoto String?
  phoneNumber  String?

  // Academic Info
  university         String?
  department         String?
  currentInstitution String?

  // Teaching Info
  teachingSubjects String[]
  preferredClasses String[]
  medium           String[]

  experienceYears Int?
  hourlyRate      Float?

  teachingStyle    String?
  demoClassOffered Boolean @default(false)

  // Location
  district String?
  area     String?

  // Approval
  isApproved Boolean @default(false)

  // Rating System
  rating       Float @default(0)
  totalReviews Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  classLevel    String?
  schoolCollege String?

  preferredSubjects String[]

  district String?
  area     String?

  guardianName  String?
  guardianPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TuitionStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

model TuitionRequest {
  id String @id @default(cuid())

  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  subject    String
  classLevel String

  medium           String?
  genderPreference String?

  district String
  area     String

  salary      Float
  daysPerWeek Int

  description String?

  status TuitionStatus @default(OPEN)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  TutorApplication TutorApplication[]
  Booking          Booking[]
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model TutorApplication {
  id String @id @default(cuid())

  tutorId String
  tutor   User   @relation(fields: [tutorId], references: [id])

  tuitionRequestId String
  tuitionRequest   TuitionRequest @relation(fields: [tuitionRequestId], references: [id])

  coverLetter String?

  status ApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Booking {
  id String @id @default(cuid())

  studentId String
  student   User   @relation("StudentBookings", fields: [studentId], references: [id])

  tutorId String
  tutor   User   @relation("TutorBookings", fields: [tutorId], references: [id])

  tuitionRequestId String         @unique
  tuitionRequest   TuitionRequest @relation(fields: [tuitionRequestId], references: [id])

  status BookingStatus @default(PENDING)

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review?
}

model Review {
  id String @id @default(cuid())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  studentId String
  student   User   @relation("StudentReviews", fields: [studentId], references: [id])

  tutorId String
  tutor   User   @relation("TutorReviews", fields: [tutorId], references: [id])

  rating Int

  comment String?

  createdAt DateTime @default(now())
}
